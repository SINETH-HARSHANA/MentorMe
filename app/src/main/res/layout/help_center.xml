<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F8F8F8">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Help Center Title -->
        <TextView
            android:id="@+id/tvHelpCenterTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Help Center"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#056C39"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"/>

        <!-- Name -->
        <TextView
            android:id="@+id/tvNameLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textStyle="bold"
            android:textColor="#056C39"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvHelpCenterTitle"
            app:layout_constraintStart_toStartOf="parent"/>

        <EditText
            android:id="@+id/etHelpName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Enter your name"
            android:inputType="textPersonName"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvNameLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Email -->
        <TextView
            android:id="@+id/tvEmailLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textStyle="bold"
            android:textColor="#056C39"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etHelpName"
            app:layout_constraintStart_toStartOf="parent"/>

        <EditText
            android:id="@+id/etHelpEmail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Enter your email"
            android:inputType="textEmailAddress"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvEmailLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Problem Description -->
        <TextView
            android:id="@+id/tvProblemLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Brief Description"
            android:textStyle="bold"
            android:textColor="#056C39"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etHelpEmail"
            app:layout_constraintStart_toStartOf="parent"/>

        <EditText
            android:id="@+id/etHelpDescription"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:hint="Describe your problem or question"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvProblemLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Submit Button -->
        <Button
            android:id="@+id/btnSubmitHelp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Send to Admin"
            android:textColor="#FFFFFF"
            android:backgroundTint="#056C39"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/etHelpDescription"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>