<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F9F9F9">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/confirm_appointment_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_confirm_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirm Appointment"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="#222222"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Choose Date -->
        <TextView
            android:id="@+id/tv_select_date_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Date"
            android:textSize="16sp"
            android:textColor="#555555"
            app:layout_constraintTop_toBottomOf="@id/tv_confirm_title"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="28dp"/>

        <DatePicker
            android:id="@+id/date_picker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:calendarViewShown="true"
            android:spinnersShown="false"
            app:layout_constraintTop_toBottomOf="@id/tv_select_date_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp"/>

        <!-- Choose Time -->
        <TextView
            android:id="@+id/tv_select_time_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Time"
            android:textSize="16sp"
            android:textColor="#555555"
            app:layout_constraintTop_toBottomOf="@id/date_picker"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="24dp"/>

        <TimePicker
            android:id="@+id/time_picker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:timePickerMode="spinner"
            app:layout_constraintTop_toBottomOf="@id/tv_select_time_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp"/>

        <!-- Brief Introduction -->
        <TextView
            android:id="@+id/tv_brief_intro_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Brief Introduction"
            android:textSize="16sp"
            android:textColor="#555555"
            app:layout_constraintTop_toBottomOf="@id/time_picker"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="24dp"/>

        <EditText
            android:id="@+id/et_brief_intro"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:hint="Write a brief introduction or reason for appointment"
            android:textSize="15sp"
            android:gravity="top|start"
            android:background="@android:drawable/edit_text"
            app:layout_constraintTop_toBottomOf="@id/tv_brief_intro_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp"
            android:padding="12dp"/>

        <!-- Send Appointment Button -->
        <Button
            android:id="@+id/btn_send_appointment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Send Appointment"
            android:textSize="16sp"
            android:backgroundTint="#4477FF"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toBottomOf="@id/et_brief_intro"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>