<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <!-- Dropdown menu (overflow) at top right -->
    <ImageButton
        android:id="@+id/btnDropdownMenu"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/round_background"
        android:background="@android:color/transparent"
        android:contentDescription="Menu"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="8dp"/>

    <!-- Dashboard title -->
    <TextView
        android:id="@+id/tvDashboardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mentee Dashboard"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#056C39"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- RecyclerView for mentor profile cards -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMentorProfiles"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvDashboardTitle"
        app:layout_constraintBottom_toTopOf="@id/btnNearbyMentors"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:scrollbars="vertical" />

    <!-- Button to choose nearby mentors in map -->
    <Button
        android:id="@+id/btnNearbyMentors"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Find Nearby Mentors"
        android:textColor="#FFFFFF"
        android:backgroundTint="#056C39"
        android:layout_marginBottom="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>