<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mentee_requests_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F9F9F9">

    <!-- Example CardView for a mentee request -->
    <androidx.cardview.widget.CardView
        android:id="@+id/mentee_request_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_mentee_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mentee Name"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#222222" />

            <TextView
                android:id="@+id/tv_request_date_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date: 2025-06-25 09:30"
                android:textSize="14sp"
                android:layout_marginTop="6dp"
                android:textColor="#555555" />

            <TextView
                android:id="@+id/tv_brief_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Brief description of the mentee's request goes here."
                android:textSize="15sp"
                android:layout_marginTop="8dp"
                android:textColor="#444444" />

            <Button
                android:id="@+id/btn_confirm_request"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirm Request"
                android:layout_marginTop="14dp"
                android:backgroundTint="#4477FF"
                android:textColor="@android:color/white"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>