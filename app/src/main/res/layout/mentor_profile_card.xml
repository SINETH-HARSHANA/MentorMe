<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="6dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp">

        <!-- Profile photo -->
        <ImageView
            android:id="@+id/imgMentorProfile"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="centerCrop"
            android:src="@drawable/round_background"
            android:background="@drawable/round_background"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:contentDescription="Mentor photo" />

        <!-- Mentor Name -->
        <TextView
            android:id="@+id/tvMentorName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Mentor Name"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#056C39"
            app:layout_constraintTop_toTopOf="@id/imgMentorProfile"
            app:layout_constraintStart_toEndOf="@id/imgMentorProfile"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            android:layout_marginStart="16dp"/>

        <!-- Mentoring Side -->
        <TextView
            android:id="@+id/tvMentoringSide"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Subject / Skill"
            android:textColor="#555"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/tvMentorName"
            app:layout_constraintStart_toStartOf="@id/tvMentorName"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp"/>

        <!-- View count icon + text -->
        <ImageView
            android:id="@+id/imgViewIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/round_background"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvMentoringSide"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvMentoringSide"
            android:layout_marginTop="8dp"
            android:contentDescription="Views"/>

        <TextView
            android:id="@+id/tvViewCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="123"
            android:textColor="#888"
            android:textSize="15sp"
            app:layout_constraintBottom_toBottomOf="@id/imgViewIcon"
            app:layout_constraintStart_toEndOf="@id/imgViewIcon"
            app:layout_constraintTop_toTopOf="@id/imgViewIcon"
            android:layout_marginStart="4dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>