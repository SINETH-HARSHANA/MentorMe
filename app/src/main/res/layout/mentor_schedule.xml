<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mentor_schedule_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F9F9F9">

    <!-- Example CardView for an accepted appointment -->
    <androidx.cardview.widget.CardView
        android:id="@+id/accepted_appointment_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"

        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_mentee_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mentee Name"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#222222" />

            <TextView
                android:id="@+id/tv_appointment_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time: 2025-06-25 10:30 AM"
                android:textSize="15sp"
                android:layout_marginTop="6dp"
                android:textColor="#555555" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>